<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <EditText
            android:id="@+id/nimInput"
            android:layout_width="365dp"
            android:layout_height="44dp"
            android:ems="10"
            android:inputType="text"
            android:text="Memasukkan nim"
            android:textColorHint="#80FFFFFF"
            tools:layout_editor_absoluteX="16dp"
            tools:layout_editor_absoluteY="27dp" />

        <EditText
            android:id="@+id/namaInput"
            android:layout_width="360dp"
            android:layout_height="42dp"
            android:ems="10"
            android:inputType="text"
            android:text="Memasukka nama"
            tools:layout_editor_absoluteX="16dp"
            tools:layout_editor_absoluteY="86dp" />

        <EditText
            android:id="@+id/kelasInput"
            android:layout_width="362dp"
            android:layout_height="40dp"
            android:ems="10"
            android:inputType="text"
            android:text="Memasukkan kelas"
            tools:layout_editor_absoluteX="19dp"
            tools:layout_editor_absoluteY="139dp" />

        <EditText
            android:id="@+id/ipkInput"
            android:layout_width="359dp"
            android:layout_height="44dp"
            android:ems="10"
            android:inputType="text"
            android:text="Memasukkan ipk"
            tools:layout_editor_absoluteX="19dp"
            tools:layout_editor_absoluteY="194dp" />

        <Button
            android:id="@+id/button"
            android:layout_width="347dp"
            android:layout_height="46dp"
            android:text="Button"
            tools:layout_editor_absoluteX="29dp"
            tools:layout_editor_absoluteY="259dp" />

        <TextView
            android:id="@+id/nimView"
            android:layout_width="343dp"
            android:layout_height="40dp"
            android:text=""
            tools:layout_editor_absoluteX="29dp"
            tools:layout_editor_absoluteY="327dp" />

        <TextView
            android:id="@+id/namaView"
            android:layout_width="338dp"
            android:layout_height="35dp"
            android:text=""
            tools:layout_editor_absoluteX="29dp"
            tools:layout_editor_absoluteY="382dp" />

        <TextView
            android:id="@+id/kelasView"
            android:layout_width="337dp"
            android:layout_height="32dp"
            android:text=""
            tools:layout_editor_absoluteX="29dp"
            tools:layout_editor_absoluteY="430dp" />

        <TextView
            android:id="@+id/ipkView"
            android:layout_width="335dp"
            android:layout_height="31dp"
            android:text=""
            tools:layout_editor_absoluteX="29dp"
            tools:layout_editor_absoluteY="477dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>